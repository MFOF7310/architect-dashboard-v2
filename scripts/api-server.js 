const express = require('express');
const cors = require('cors');
const cookieParser = require('cookie-parser');
const path = require('path');

module.exports = function startAPIServer(client, db) {
    const app = express();
    
    // Middleware
    app.use(cors({
        origin: ['https://architect-dashboard-v2.pages.dev', 'http://localhost:3000'],
        credentials: true
    }));
    app.use(express.json());
    app.use(cookieParser());
    
    // Serve dashboard HTML
    app.use(express.static(path.join(__dirname, '..', 'dashboard')));
    
    // Load dashboard API routes
    require('./dashboard-api.js')(app, client, db);
    
    // Fallback: serve index.html for all other routes
    app.get('*', (req, res) => {
        res.sendFile(path.join(__dirname, '..', 'dashboard', 'index.html'));
    });
    
    const PORT = process.env.DASHBOARD_PORT || 3000;
    app.listen(PORT, () => {
        console.log(`\x1b[32m[DASHBOARD]\x1b[0m Server running on port ${PORT}`);
    });
};